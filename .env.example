# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=...

# Google Sheets (Brain Archive)
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
BRAIN_SHEET_ID=1abc...

# Multi-tenancy (дефолтний клієнт для розробки)
DEFAULT_CLIENT_ID=etalhome

# Sales Agent — per клієнт (формат: CLIENT_NAME_<CLIENT_ID_UPPERCASE>)
CLIENT_NAME_ETALHOME=Etalhome
KB_SHEET_ID_ETALHOME=1abc...  # ID Google Sheets таблиці Knowledge Base etalhome

# Менеджер (ескалація)
MANAGER_TELEGRAM_ID=123456789

# Оточення
ENVIRONMENT=development  # development | production
